{
  "name": "@kubohiroya/vite-plugin-turbowarp-extension",
  "version": "0.1.0",
  "description": "A Vite plugin for building TypeScript projects as single-file TurboWarp extensions.",
  "type": "module",
  "license": "MPL-2.0",
  "author": "Hiroya Kubo",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "npm run typecheck && npm run test && npm run build"
  },
  "peerDependencies": {
    "vite": ">=6.0.0"
  },
  "devDependencies": {
    "rollup": "^4.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0"
  }
}
