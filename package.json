{
  "name": "@kubohiroya/vite-plugin-turbowarp-extension",
  "version": "0.1.0",
  "description": "A Vite plugin for building TypeScript projects as single-file TurboWarp extensions.",
  "type": "module",
  "license": "MPL-2.0",
  "author": "Hiroya Kubo <hiroya@cuc.ac.jp>",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "pnpm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "pnpm run typecheck && pnpm run test && pnpm run build"
  },
  "peerDependencies": {
    "vite": ">=6.0.0"
  },
  "devDependencies": {
    "rollup": "^4.62.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "vitest": "^3.2.7"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.26.1"
  },
  "packageManager": "pnpm@10.29.3"
}
